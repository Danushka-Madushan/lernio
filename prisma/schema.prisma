datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

enum Role {
  ADMIN
  STUDENT
}

enum Grade {
  GRADE_6
  GRADE_7
  GRADE_8
  GRADE_9
  GRADE_10
  GRADE_11
}

enum VideoVisibility {
  PUBLIC
  GRADE
}

enum AccessMode {
  GRADE
  CUSTOM
}

model User {
  id             String     @id @default(uuid())
  username       String     @unique
  hashedPassword String
  role           Role       @default(STUDENT)
  grade          Grade?
  activeFrom     DateTime?
  activeTo       DateTime?
  accessMode     AccessMode @default(GRADE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  comments     Comment[]
  likes        Like[]
  views        View[]
  customVideos CustomVideoAccess[]
}

model Video {
  id                       String          @id @default(uuid())
  title                    String
  description              String?
  cloudflareR2Key          String
  cloudflareR2ThumbnailKey String?
  grade                    Grade?
  visibility               VideoVisibility @default(PUBLIC)
  viewsCount               Int             @default(0)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  comments     Comment[]
  likes        Like[]
  views        View[]
  customVideos CustomVideoAccess[]
}

model ZoomAccount {
  id           String     @id @default(uuid())
  name         String
  email        String
  accountId    String
  clientId     String
  clientSecret String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  zoomLinks    ZoomLink[]
}

model ZoomLink {
  id          String   @id @default(uuid())
  title       String
  scheduledAt DateTime
  grade       Grade?
  link        String   // Student join URL
  
  zoomAccountId String?
  zoomAccount   ZoomAccount? @relation(fields: [zoomAccountId], references: [id], onDelete: SetNull)
  meetingId     String?
  startUrl      String?
  duration      Int?
  isRecurring   Boolean      @default(false)
  hostVideo     Boolean      @default(false)
  participantVideo Boolean   @default(false)
  waitingRoom   Boolean      @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model CustomVideoAccess {
  id      String @id @default(uuid())
  userId  String
  videoId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model View {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}
